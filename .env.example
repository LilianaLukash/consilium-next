OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_APP_NAME=Consilium-Next
OPENROUTER_APP_URL=http://localhost:8001
APP_PUBLIC_URL=http://localhost:8001

ENVIRONMENT=development
# MASTER_MODE=true only on local machine — NEVER in production
MASTER_MODE=false

JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback

# Email (optional SMTP; dev logs links to console)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@consilium.app

# Billing
BILLING_MARKUP_MULTIPLIER=1.4
MIN_BALANCE_TO_RUN_USD=0.05
SIGNUP_BONUS_USD=2.0
GUEST_FREE_RUNS=1

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Models
MODEL_DIATOR=x-ai/grok-4.3
MODEL_VISIONARY=nousresearch/hermes-4-70b
MODEL_ARCHITECT=anthropic/claude-sonnet-4
MODEL_CRITIC=anthropic/claude-sonnet-4
MODEL_SYNTHESIS=google/gemini-2.5-pro-preview
